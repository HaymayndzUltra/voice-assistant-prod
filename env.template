# =============================================================================
# AI SYSTEM DOCKER ENVIRONMENT CONFIGURATION TEMPLATE
# Copy this file to .env and modify as needed
# =============================================================================

# =============================================================================
# CONFIGURATION SYSTEM (V3)
# =============================================================================
# Use unified configuration system with Docker overrides
CONFIG_OVERRIDE=docker
MACHINE_TYPE=mainpc
MACHINE_ROLE=MAIN_PC

# =============================================================================
# DEPLOYMENT SETTINGS
# =============================================================================
COMPOSE_PROJECT_NAME=ai-system
COMPOSE_FILE=docker-compose.yml

# Machine Configuration
MACHINE_TYPE_MAINPC=mainpc
MACHINE_TYPE_PC2=pc2

# =============================================================================
# CONTAINER PATHS (V3 ALIGNED)
# =============================================================================
# Align with config/overrides/docker.yaml paths
PROJECT_ROOT=/app
CONFIG_DIR=/app/config
LOG_DIR=/app/logs
DATA_DIR=/app/data
CACHE_DIR=/app/cache
MODELS_DIR=/app/models

# =============================================================================
# NETWORK CONFIGURATION
# =============================================================================
MAINPC_NETWORK_SUBNET=172.20.0.0/16
PC2_NETWORK_SUBNET=172.21.0.0/16

# Cross-machine communication
MAINPC_IP=192.168.100.16
PC2_IP=192.168.100.17

# =============================================================================
# VOLUME PATHS
# =============================================================================
# Model storage (adjust path as needed)
MODELS_PATH=/home/haymayndz/AI_System_Monorepo/models
HUGGINGFACE_CACHE_PATH=/home/haymayndz/.cache/huggingface

# Application directories
LOGS_PATH=./logs
CONFIG_PATH=./config
DATA_PATH=./data

# =============================================================================
# GPU CONFIGURATION
# =============================================================================
# MainPC GPU Settings (RTX 4090)
MAINPC_GPU_DEVICE_ID=0
MAINPC_VRAM_LIMIT_MB=20000
MAINPC_GPU_MEMORY_FRACTION=0.8

# PC2 GPU Settings (RTX 3060)
PC2_GPU_DEVICE_ID=0
PC2_VRAM_LIMIT_MB=10000
PC2_GPU_MEMORY_FRACTION=0.8

# NVIDIA Docker Runtime
NVIDIA_VISIBLE_DEVICES=all
NVIDIA_DRIVER_CAPABILITIES=compute,utility

# =============================================================================
# MODEL CONFIGURATION
# =============================================================================
# Enable model management
ENABLE_MODEL_LOADING=true
ENABLE_GGUF_MODELS=true
MODEL_CACHE_SIZE_GB=2

# Model preloading
PRELOAD_MODELS=true
DEFAULT_MODEL=phi-3-mini

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================
LOG_LEVEL=INFO
LOG_FORMAT=json
ENABLE_DEBUG_LOGGING=false

# =============================================================================
# SERVICE DISCOVERY (V3 ALIGNED)
# =============================================================================
SERVICE_DISCOVERY_MODE=container_dns
ENABLE_CROSS_MACHINE_DISCOVERY=true

# Discovery endpoints
MAINPC_DISCOVERY_ENDPOINT=http://mainpc-observability.cross_machine:9000
PC2_DISCOVERY_ENDPOINT=http://pc2-observability.cross_machine:9100

# =============================================================================
# CONTAINER RUNTIME (V3 ALIGNED)
# =============================================================================
# Container-specific settings from docker.yaml override
PYTHONUNBUFFERED=1
PYTHONDONTWRITEBYTECODE=1
PIP_NO_CACHE_DIR=1

# Health check settings
HEALTH_CHECK_ENABLED=true
HEALTH_CHECK_ENDPOINT=/health
ENABLE_CONTAINER_METRICS=true 